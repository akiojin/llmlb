{
  "enableAllProjectMcpServers": true,
  "enabledPlugins": {
    "clangd-lsp@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "github@akiojin-skills": true,
    "github@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "ralph-wiggum@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": false,
    "serena@claude-plugins-official": true,
    "worktree-protection-hooks@gwt-plugins": true
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "command": "bash .claude/hooks/scripts/forward-gwt-hook.sh Notification",
            "type": "command"
          }
        ],
        "matcher": "*"
      },
      {
        "hooks": [
          {
            "command": ".claude/hooks/scripts/gwt-forward-hook.sh Notification",
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "bash .claude/hooks/scripts/forward-gwt-hook.sh PostToolUse",
            "type": "command"
          }
        ],
        "matcher": "*"
      },
      {
        "hooks": [
          {
            "command": ".claude/hooks/scripts/gwt-forward-hook.sh PostToolUse",
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "bash .claude/hooks/block-quality-checks-in-task.sh",
            "type": "command"
          }
        ],
        "matcher": "Task"
      },
      {
        "hooks": [
          {
            "command": "bash .claude/hooks/scripts/forward-gwt-hook.sh PreToolUse",
            "type": "command"
          }
        ],
        "matcher": "*"
      },
      {
        "hooks": [
          {
            "command": "bash .claude/hooks/scripts/block-git-branch-ops.sh",
            "type": "command"
          },
          {
            "command": "bash .claude/hooks/scripts/block-cd-command.sh",
            "type": "command"
          },
          {
            "command": "bash .claude/hooks/scripts/block-file-ops.sh",
            "type": "command"
          },
          {
            "command": "bash .claude/hooks/scripts/block-git-dir-override.sh",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": ".claude/hooks/scripts/gwt-forward-hook.sh PreToolUse",
            "type": "command"
          }
        ],
        "matcher": "*"
      },
      {
        "hooks": [
          {
            "command": ".claude/hooks/scripts/gwt-block-git-branch-ops.sh",
            "type": "command"
          },
          {
            "command": ".claude/hooks/scripts/gwt-block-cd-command.sh",
            "type": "command"
          },
          {
            "command": ".claude/hooks/scripts/gwt-block-file-ops.sh",
            "type": "command"
          },
          {
            "command": ".claude/hooks/scripts/gwt-block-git-dir-override.sh",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "bash .claude/hooks/scripts/forward-gwt-hook.sh Stop",
            "type": "command"
          }
        ],
        "matcher": "*"
      },
      {
        "hooks": [
          {
            "command": ".claude/hooks/scripts/gwt-forward-hook.sh Stop",
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "bash .claude/hooks/scripts/forward-gwt-hook.sh UserPromptSubmit",
            "type": "command"
          }
        ],
        "matcher": "*"
      },
      {
        "hooks": [
          {
            "command": ".claude/hooks/scripts/gwt-forward-hook.sh UserPromptSubmit",
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ]
  }
}