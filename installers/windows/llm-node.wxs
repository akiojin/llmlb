<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product
    Id="*"
    Name="LLM Node"
    Language="1041"
    Version="$(var.ProductVersion)"
    Manufacturer="LLM Router"
    Codepage="65001"
    UpgradeCode="{E22A1C40-C708-46CE-B722-2EE7821484BF}"
  >
    <Package
      InstallerVersion="500"
      Compressed="yes"
      InstallScope="perMachine"
      Platform="x64"
    />

    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />

    <MajorUpgrade
      AllowDowngrades="no"
      DowngradeErrorMessage="A newer version of LLM Node is already installed."
    />

    <Feature Id="MainFeature" Title="LLM Node" Level="1">
      <!-- Generated at build time via heat.exe -->
      <ComponentGroupRef Id="NodeRuntimeComponents" />
      <ComponentGroupRef Id="NodeUiComponents" />
    </Feature>
  </Product>

  <Fragment>
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLFOLDER" Name="LLM Node" />
      </Directory>
      <Directory Id="ProgramMenuFolder">
        <Directory Id="ApplicationProgramsFolder" Name="LLM Node" />
      </Directory>
    </Directory>
  </Fragment>

  <Fragment>
    <!-- Paths are resolved relative to repository root (workflow runs from repo root) -->
    <Icon Id="NodeIcon" SourceFile="assets\\icons\\node.ico" />
  </Fragment>

  <Fragment>
    <ComponentGroup Id="NodeUiComponents">
      <Component Id="NodeStartMenuShortcut" Directory="ApplicationProgramsFolder" Guid="{BA2A55B9-239F-4B98-A9E5-5469B0EFD0FF}" Win64="yes">
        <Shortcut
          Id="NodeShortcut"
          Name="LLM Node"
          Description="LLM Node を起動"
          Target="[INSTALLFOLDER]llm-node.exe"
          WorkingDirectory="INSTALLFOLDER"
          Icon="NodeIcon"
          IconIndex="0"
        />
        <RemoveFolder Id="RemoveNodeProgramsFolder" Directory="ApplicationProgramsFolder" On="uninstall" />
        <RegistryValue Root="HKCU" Key="Software\\LLMRouter" Name="NodeShortcut" Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>
</Wix>
